usage: agentrepl-test [-c key=value ...] [-raw] [-V] [-h]

flags:
  -c key=value   set an agentkit config value (repeatable); see config keys via /help at runtime
  -raw           emit the raw, undecorated message stream
  -V, --version   show the version and exit
  -h, -help      show this catalog and exit

defaults:
  provider=openai   model=gpt-5.6-sol   auth=sub

providers:
  anthropic    auth=key  (ANTHROPIC_API_KEY)
  google       auth=key  (GEMINI_API_KEY)
  openai       auth=key  (OPENAI_API_KEY)
               auth=sub  (auth_file=~/.agentrepl/auth.json; create with oauth-login)
  openrouter   auth=key  (OPENROUTER_API_KEY)
  zai          auth=key  (ZAI_API_KEY)

models:
  anthropic
    claude-fable-5           effort={low|*medium|high|xhigh|max}
    claude-haiku-4-5         thinking_budget=<1024–4096>  (default off)
    claude-opus-4-8          effort={low|medium|*high|xhigh|max}
    claude-sonnet-4-6        effort={low|medium|*high|max}
    claude-sonnet-5          effort={low|*medium|high|xhigh|max}
  google
    gemini-2.5-flash         thinking_budget=<0–24576>  (0=off, -1=*dynamic)
    gemini-2.5-pro           thinking_budget=<128–32768>  (-1=*dynamic)
    gemini-3.1-flash-lite    thinking_level={minimal|low|*medium|high}
    gemini-3.1-pro-preview   thinking_level={low|medium|*high}
    gemini-3.5-flash         thinking_level={minimal|low|*medium|high}
  openai
    gpt-5.4                  effort={*none|low|medium|high|xhigh}
    gpt-5.4-mini             effort={*none|low|medium|high|xhigh}
    gpt-5.4-nano             effort={*none|low|medium|high|xhigh}
    gpt-5.5                  effort={none|low|*medium|high|xhigh}
    gpt-5.5-pro              effort={*high|xhigh}
    gpt-5.6-luna             effort={none|low|*medium|high|xhigh}
    gpt-5.6-sol              effort={none|low|*medium|high|xhigh}
    gpt-5.6-terra            effort={none|low|*medium|high|xhigh}
  openrouter
    deepseek-v4-flash        thinking={*on|off}
    deepseek-v4-pro          thinking={*on|off}
    glm-4.6  -> z-ai/glm-4.6  thinking={*on|off}
    glm-4.7  -> z-ai/glm-4.7  thinking={*on|off}
    glm-5.1  -> z-ai/glm-5.1  thinking={*on|off}
    glm-5.2  -> z-ai/glm-5.2  effort={high|*max}  (+ toggle)
    grok-4.20                thinking={*on|off}
    grok-4.20-multi-agent    thinking={*on|off}
    grok-4.3                 thinking={*on|off}
    grok-4.5                 thinking={*on|off}
    kimi-k2.6                thinking={*on|off}
    kimi-k2.7-code           thinking={*on|off}
    kimi-k3                  thinking={*on|off}
  zai
    glm-4.6                  thinking={*on|off}
    glm-4.7                  thinking={*on|off}
    glm-5.1                  thinking={*on|off}
    glm-5.2                  effort={high|*max}  (+ toggle)

a bare -c model=NAME must name a cataloged model (provider is derived from it).
any other model requires -c provider=... too and passes through unvalidated:
no pricing (cost reports 0), reasoning keys unchecked.
